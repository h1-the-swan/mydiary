{
  "name": "mydiary-vuetify",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "vite --port 3001 --host 0.0.0.0",
    "generateClientAPI": "node ./scripts/generateAPI.mjs && orval --config ./orval.config.js",
    "generateAndStart": "npm run generateClientAPI && npm run dev",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint . --fix"
  },
  "dependencies": {
    "@mdi/font": "7.4.47",
    "@popperjs/core": "^2.11.8",
    "axios": "^1.18.1",
    "core-js": "^3.49.0",
    "markdown-it": "^14.3.0",
    "pinia": "^4.0.2",
    "roboto-fontface": "^0.10.0",
    "v-calendar": "^3.1.2",
    "vue": "^3.5.40",
    "vue-router": "^5.2.0",
    "vuetify": "^4.1.5",
    "webfontloader": "^1.6.28"
  },
  "overrides": {
    "lodash": "^4.18.1"
  },
  "devDependencies": {
    "@babel/types": "^8.0.4",
    "@eslint/js": "^10.0.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.5.5",
    "@types/webfontloader": "^1.6.38",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/eslint-config-typescript": "^14.9.0",
    "eslint": "^10.7.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "orval": "^8.22.0",
    "sass": "^1.101.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.5",
    "vite-plugin-vuetify": "^2.1.3",
    "vue-tsc": "^3.3.7"
  }
}
